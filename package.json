{
   "name": "instagram-backend",
   "version": "1.0.0",
   "license": "MIT",
   "scripts": {
      "build": "tsc",
      "dev": "nodemon src/index.ts --exec 'ts-node src/index.ts'",
      "prebuild": "mkdir dist",
      "start": "npm run compile && node ./dist/index.js"
   },
   "dependencies": {
      "@apollo/server": "^4.3.0",
      "bcryptjs": "^2.4.3",
      "body-parser": "^1.20.1",
      "cloudinary": "^1.33.0",
      "cors": "^2.8.5",
      "dotenv": "^16.0.3",
      "express": "^4.18.2",
      "graphql": "^16.6.0",
      "graphql-upload": "^16.0.2",
      "graphql-upload-minimal": "^1.5.4",
      "jsonwebtoken": "^9.0.0",
      "mongoose": "^6.8.1",
      "streamifier": "^0.1.1"
   },
   "devDependencies": {
      "@types/bcryptjs": "^2.4.2",
      "@types/cors": "^2.8.13",
      "@types/jsonwebtoken": "^9.0.0",
      "@types/node": "^18.11.17",
      "nodemon": "^2.0.20",
      "ts-node": "^10.9.1",
      "typescript": "^4.9.4"
   },
   "prettier": {
      "printWidth": 110,
      "semi": false,
      "singleQuote": true,
      "trailingComma": "es5",
      "tabWidth": 3,
      "endOfLine": "auto",
      "bracketSameLine": true
   }
}
